# Root Environment Variables for Docker Compose

# PostgreSQL Configuration
POSTGRES_USER=lostfound_user
POSTGRES_PASSWORD=secure_password_change_me
POSTGRES_DB=lostfound_db
DATABASE_URL=postgresql://lostfound_user:secure_password_change_me@postgres:5432/lostfound_db

# MinIO Configuration
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_change_me
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_change_me

# FastAPI Backend
BACKEND_PORT=8000
JWT_SECRET_KEY=your_jwt_secret_key_change_me_32_chars_minimum
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
DEBUG_MODE=False

# SMTP Email Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=noreply@lostfound.app

# Frontend
FRONTEND_PORT=3000
VITE_API_BASE_URL=http://localhost:8000/api

# Logging
LOG_LEVEL=INFO
