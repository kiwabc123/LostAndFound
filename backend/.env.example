# Backend Environment Variables

# Database
DATABASE_URL=postgresql+asyncpg://lostfound_user:secure_password_change_me@localhost:5432/lostfound_db

# JWT Configuration
JWT_SECRET_KEY=your_jwt_secret_key_change_me_32_chars_minimum
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=7

# MinIO Configuration
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_change_me

# SMTP Email Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=noreply@lostfound.app

# Logging
LOG_LEVEL=INFO
DEBUG_MODE=True

# Application
APP_NAME=Lost & Found API
APP_VERSION=1.0.0
